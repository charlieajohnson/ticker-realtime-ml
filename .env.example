# Data provider — synthetic runs out of the box, no API key needed
API_PROVIDER=synthetic

# Only needed if API_PROVIDER=finnhub
# FINNHUB_API_KEY=your_api_key_here

# Only needed if API_PROVIDER=alpha_vantage
# ALPHA_VANTAGE_API_KEY=your_api_key_here

# Symbols to track
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,NVDA,TSLA,META,JPM

# Pipeline
INGEST_INTERVAL_S=10
FEATURE_WINDOW_SIZE=60
INFERENCE_INTERVAL_S=5

# Database
DUCKDB_PATH=data/ticker.db

# Logging
LOG_LEVEL=INFO
