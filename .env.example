# Data provider (alpha_vantage | polygon | finnhub)
API_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=your_api_key_here
# POLYGON_API_KEY=your_api_key_here
# FINNHUB_API_KEY=your_api_key_here

# Symbols to track
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,NVDA,TSLA,META,JPM

# Pipeline
INGEST_INTERVAL_S=1
FEATURE_WINDOW_SIZE=60
INFERENCE_INTERVAL_S=5

# Database
DUCKDB_PATH=data/ticker.db

# Logging
LOG_LEVEL=INFO
